{
  "name": "xeno-crm-root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:channel": "npm run dev --workspace=apps/channel-service",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:channel\"",
    "build": "npm run build --workspaces --if-present",
    "build:web": "npm run build --workspace=apps/web",
    "build:channel": "npm run build --workspace=apps/channel-service",
    "start:web": "npm run start --workspace=apps/web",
    "start:channel": "npm run start --workspace=apps/channel-service",
    "start:channel:prod": "npm run start:prod --workspace=apps/channel-service"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.3.3"
  }
}
